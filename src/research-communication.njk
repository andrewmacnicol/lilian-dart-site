---
layout: base.njk
title: "Research Communication — Lilian Dart"
description: "Conference presentations, public writing, and media appearances by Lilian Dart, including podcast features."
activePage: research-communication
permalink: research-communication.html
canonicalPath: /research-communication
---
<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-label">{{ researchCommunication.hero_label }}</p>
    <h1>{{ researchCommunication.hero_title }}</h1>
  </div>
</div>

<!-- INTRO -->
<div class="content-section">
  <p>{{ researchCommunication.intro_paragraph }}</p>
</div>

<!-- PRESENTATIONS & MEDIA -->
<div class="content-section">
  <p class="section-label">Presentations & media</p>
  <div class="pub-list">
    {% for item in researchCommunication.items | sort(true, false, "sort_date") %}
      {% if item.type == "podcast" %}
      <div class="pub-card">
        <p class="pub-year">{{ item.date }}</p>
        <p class="pub-title">{{ item.title }}</p>
        <p class="pub-venue">{{ item.show }}</p>
        <iframe width="100%" height="180" frameborder="no" scrolling="no" seamless src="{{ item.embed_url }}" title="{{ item.title }}" style="margin-top: 1rem;"></iframe>
        <a href="{{ item.episode_url }}" target="_blank" style="display: inline-block; margin-top: 0.75rem; font-size: 0.85rem; color: var(--green-deep);">
          View episode page
        </a>
      </div>
      {% else %}
      <div class="pub-card">
        <p class="pub-year">{{ item.date }}</p>
        <p class="pub-title">{{ item.title }}</p>
        <p class="pub-venue">{{ item.venue }}{% if item.location %}, {{ item.location }}{% endif %}</p>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
