---
layout: base.njk
title: "CV — Lilian Dart"
description: "Curriculum vitae of Lilian Dart, PhD candidate in Human Geography at the University of Toronto."
activePage: cv
permalink: cv.html
canonicalPath: /cv
---
<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-label">{{ cv.hero_label }}</p>
    <h1>{{ cv.hero_title }}</h1>
  </div>
</div>

<div class="content-section">

  <!-- DOWNLOAD BLOCK -->
  <div class="cv-download-block">
    <div class="cv-download-text">
      <h2>Download full CV</h2>
      <p>PDF · Last updated {{ cv.pdf_last_updated }}</p>
    </div>
    <a href="{{ cv.pdf_filename or '#' }}" class="btn btn-primary" download>
      Download CV (PDF)
    </a>
  </div>

  {% if cv.pdf_filename %}
  <!-- EMBEDDED PDF -->
  <div class="cv-pdf-embed">
    <object data="{{ cv.pdf_filename }}" type="application/pdf">
      <p class="cv-pdf-fallback">
        Your browser can't display the PDF inline.
        <a href="{{ cv.pdf_filename }}">Click here to view or download it</a>.
      </p>
    </object>
  </div>
  {% endif %}

</div>
