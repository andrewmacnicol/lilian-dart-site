---
layout: base.njk
title: "CV — Lilian Dart"
activePage: cv
permalink: cv.html
---
<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-label">{{ cv.hero_label }}</p>
    <h1>{{ cv.hero_title }}</h1>
  </div>
</div>

<div class="content-section">

  <!-- DOWNLOAD BLOCK -->
  <div class="cv-download-block">
    <div class="cv-download-text">
      <h2>Download full CV</h2>
      <p>PDF · Last updated {{ cv.pdf_last_updated }}</p>
    </div>
    <a href="{{ cv.pdf_filename or '#' }}" class="btn btn-primary" download>
      Download CV (PDF)
    </a>
  </div>

  <!-- EDUCATION (shared with About) -->
  <div class="cv-section">
    <p class="cv-section-title">Education</p>
    {% for edu in about.education %}
    <div class="cv-entry">
      <span class="cv-year">{{ edu.year }}</span>
      <div class="cv-content">
        <h3>{{ edu.degree }}</h3>
        <p>{{ edu.school }}</p>
        {% if edu.supervisor %}<p class="cv-detail">Supervisor: {{ edu.supervisor }}</p>{% endif %}
        {% if edu.minor %}<p class="cv-detail">Minor: {{ edu.minor }}</p>{% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- PUBLICATIONS (shared with Research) -->
  <div class="cv-section">
    <p class="cv-section-title">Publications</p>
    {% for pub in research.publications %}
    <div class="cv-entry">
      <span class="cv-year">{{ pub.year }}</span>
      <div class="cv-content">
        <h3>{{ pub.title }}</h3>
        <p>{{ pub.authors }}</p>
        <p class="cv-detail">{{ pub.venue }}</p>
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- TEACHING (shared with Teaching) -->
  <div class="cv-section">
    <p class="cv-section-title">Teaching</p>
    {% for course in teaching.courses %}
    <div class="cv-entry">
      <span class="cv-year">{{ course.period_tag }}</span>
      <div class="cv-content">
        <h3>{{ course.title }}</h3>
        <p>{{ course.role }}</p>
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- FIELDS OF STUDY (shared with About) -->
  <div class="cv-section">
    <p class="cv-section-title">Fields of study</p>

    <div class="cv-entry">
      <span class="cv-year">Primary</span>
      <div class="cv-content">
        <h3>{{ about.fields_of_study | join(' · ') }}</h3>
      </div>
    </div>

    <div class="cv-entry">
      <span class="cv-year">Areas</span>
      <div class="cv-content">
        <p style="font-size:0.9rem; color:var(--ink-light);">{{ about.areas_of_interest }}</p>
      </div>
    </div>
  </div>

  <!-- CONTACT (shared site-wide) -->
  <div class="cv-section">
    <p class="cv-section-title">Contact</p>

    <div class="cv-entry">
      <span class="cv-year">Email</span>
      <div class="cv-content">
        <a href="mailto:{{ site.email }}" style="color:var(--green-deep); font-size:0.9rem;">{{ site.email }}</a>
      </div>
    </div>

    <div class="cv-entry">
      <span class="cv-year">Office</span>
      <div class="cv-content">
        <p>{{ site.office }}</p>
        <p>{{ site.office_line2 }}</p>
      </div>
    </div>

    <div class="cv-entry">
      <span class="cv-year">Online</span>
      <div class="cv-content">
        <p><a href="{{ site.linkedin }}" target="_blank" style="color:var(--green-deep);">LinkedIn</a> · <a href="{{ site.twitter }}" target="_blank" style="color:var(--green-deep);">X / Twitter</a></p>
      </div>
    </div>
  </div>

  <div class="note-box">
    <p>For the most complete and current version of my CV, please download the PDF above or <a href="mailto:{{ site.email }}">contact me directly</a>.</p>
  </div>

</div>
